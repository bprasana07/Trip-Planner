# ─────────────────────────────────────────────────────────────
# Trip Advisor Agent — Environment Variables
# Copy this file to .env and fill in your actual keys
# ─────────────────────────────────────────────────────────────

# REQUIRED — LLM provider (choose one)
# Default: OpenAI GPT-4o
OPENAI_API_KEY=your_openai_key_here

# OR use Anthropic Claude instead:
# ANTHROPIC_API_KEY=your_anthropic_key_here
# (and change model_name in hocon to "claude-sonnet-4-6")

# ─────────────────────────────────────────────────────────────
# WEATHER TOOL — Free signup at openweathermap.org
# ─────────────────────────────────────────────────────────────
OPENWEATHERMAP_API_KEY=your_openweathermap_key_here

# ─────────────────────────────────────────────────────────────
# ATTRACTIONS TOOL — Free signup at opentripmap.io
# ─────────────────────────────────────────────────────────────
OPENTRIPMAP_API_KEY=your_opentripmap_key_here

# ─────────────────────────────────────────────────────────────
# HOTELS TOOL — Optional. Free signup at rapidapi.com
# Without this, the agent uses realistic mock hotel data.
# ─────────────────────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here
